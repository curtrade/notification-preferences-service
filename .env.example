# Copy to .env and adjust for your environment.

# HTTP port the service listens on
PORT=3000

# Log level: error | warn | log | debug | verbose
LOG_LEVEL=log

# PostgreSQL connection string used by Prisma.
# For docker-compose this points at the bundled "postgres" service.
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/notification_preferences?schema=public
